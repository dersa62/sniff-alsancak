<IfModule mod_rewrite.c>
  RewriteEngine On

  # Canonical host: www -> non-www
  RewriteCond %{HTTP_HOST} ^www\.sniffalsancak\.com$ [NC]
  RewriteRule ^ https://sniffalsancak.com%{REQUEST_URI} [L,R=301]

  # Force HTTPS on canonical host
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} ^sniffalsancak\.com$ [NC]
  RewriteRule ^ https://sniffalsancak.com%{REQUEST_URI} [L,R=301]
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresDefault "access plus 7 days"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js|mjs|png|jpe?g|gif|svg|webp|ico|woff2?|ttf|otf|mp4|webm)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:html)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>

  <FilesMatch "\.(?:php)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  </FilesMatch>

  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

FileETag None
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
